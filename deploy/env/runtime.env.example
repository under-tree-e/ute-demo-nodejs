# Illustrates the current, fully non-secret runtime.env for this service.
# Rendered by ute-ansible's ute_compose_release role at the canonical
# /opt/runtime/ute-demo-nodejs.env path. No Vault Agent, AppRole or Vault
# policy is required for this first deploy since no secret is declared.
# Do not commit a real rendered file.
PORT=3000
NODE_ENV=production
DISABLE_METRICS=false
