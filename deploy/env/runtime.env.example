# This illustrates the file rendered by Vault Agent on the target host.
# It is not a deployable secret file and must never be committed with real values.
NODE_ENV=production
PORT=3000
DISABLE_METRICS=false
SESSION_COOKIE_SECURE=true
TRUST_PROXY=true

# Required; rendered from Vault key SESSION_SECRET.
# SESSION_SECRET=<provided-by-vault-agent>
